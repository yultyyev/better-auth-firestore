{
  "name": "better-auth-firestore",
  "version": "0.0.0-development",
  "private": false,
  "description": "Firestore adapter for Better Auth (Firebase Admin SDK)",
  "author": "Slava Yultyyev <yultyyev@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "firestore.indexes.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "test": "./tests/test.sh",
    "lint": "biome check --formatter-enabled=false",
    "lint:fix": "biome check --write",
    "lint:fix:unsafe": "biome check --write --unsafe",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yultyyev/better-auth-firestore.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "better-auth",
    "firebase",
    "firestore",
    "adapter",
    "authjs",
    "nextauth",
    "oauth",
    "session",
    "typescript"
  ],
  "peerDependencies": {
    "better-auth": "*",
    "firebase-admin": ">=13",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "@tootallnate/once@<3.0.1": ">=3.0.1",
      "kysely@<=0.28.13": ">=0.28.14",
      "kysely@>=0.28.12 <=0.28.13": ">=0.28.14",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.6": ">=5.5.7",
      "micromatch>picomatch": "^2.3.2",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "brace-expansion@<5.0.5": ">=5.0.5",
      "node-forge@<1.4.0": ">=1.4.0",
      "node-forge@<=1.3.3": ">=1.4.0"
    }
  }
}
